# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://admin:password123@localhost:27017/tech-news?authSource=admin

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=7d

# External APIs (optional for news aggregation)
NEWS_API_KEY=your_news_api_key
GNEWS_API_KEY=your_gnews_api_key

# CORS
CLIENT_URL=http://localhost:3000
